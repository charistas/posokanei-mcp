{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.charistas/posokanei-mcp",
  "description": "Unofficial read-only MCP server for Greek supermarket price data from PosoKanei.",
  "repository": {
    "url": "https://github.com/charistas/posokanei-mcp",
    "source": "github"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "posokanei-mcp",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "POSOKANEI_CACHE_TTL_MS",
          "description": "Optional cache TTL in milliseconds.",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "POSOKANEI_MIN_INTERVAL_MS",
          "description": "Optional minimum delay between outbound PosoKanei API requests.",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
